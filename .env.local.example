# ─────────────────────────────────────────────────────────────
# DocuSign credentials (JWT Grant auth — recommended for server-to-server)
# Get these from your DocuSign Developer (demo) account: https://developers.docusign.com
# ─────────────────────────────────────────────────────────────

# Integration Key (Client ID) for your app
DOCUSIGN_INTEGRATION_KEY=your-integration-key-guid

# The API user's GUID (Settings > Apps and Keys > "API Username")
DOCUSIGN_USER_ID=your-api-user-guid

# Your account's API base path.
#   Demo/sandbox:   https://demo.docusign.net/restapi
#   Production:     https://www.docusign.net/restapi  (varies by region, e.g. eu / au)
DOCUSIGN_BASE_PATH=https://demo.docusign.net/restapi

# Your DocuSign API Account ID (Settings > Apps and Keys > "API Account ID")
DOCUSIGN_ACCOUNT_ID=your-api-account-id

# OAuth host used to mint the JWT access token.
#   Demo:        account-d.docusign.com
#   Production:  account.docusign.com
DOCUSIGN_OAUTH_HOST=account-d.docusign.com

# RSA private key for JWT. Use a single line with \n escapes for line breaks.
DOCUSIGN_RSA_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nMIIE...\n-----END RSA PRIVATE KEY-----"

# ─────────────────────────────────────────────────────────────
# Client-side (must be NEXT_PUBLIC_ to reach the browser)
# ─────────────────────────────────────────────────────────────

# Same integration key, exposed to the browser for DocuSign JS loadDocuSign()
NEXT_PUBLIC_DOCUSIGN_INTEGRATION_KEY=your-integration-key-guid

# DocuSign JS bundle:
#   Demo:        https://js-d.docusign.com/bundle.js
#   Production:  https://js.docusign.com/bundle.js
NEXT_PUBLIC_DOCUSIGN_JS_BUNDLE=https://js-d.docusign.com/bundle.js

# The "apps" domain DocuSign uses for the focused-view iframe.
#   Demo:        https://apps-d.docusign.com
#   Production:  https://apps.docusign.com
NEXT_PUBLIC_DOCUSIGN_APPS_ORIGIN=https://apps-d.docusign.com

# The origin of THIS app (used in frameAncestors). No trailing slash.
NEXT_PUBLIC_APP_ORIGIN=http://localhost:3000
